{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Configure Debug",
            "type": "shell",
            "command": "${config:cmake.cmakePath}",
            "args": [
                "--preset",
                "Debug"
            ],
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "Flash Board",
            "type": "shell",
            "command": "/bin/sh",
            "args": [
                "${workspaceFolder}/.vscode/flash_board.sh"
            ],
            "options": {
                "env": {
                    "BUILD_DIR": "${workspaceFolder}/build/Debug",
                    "TARGET_NAME": "hard-fs-dashboard"
                }
            },
            "detail": "Program QSPI and internal flash on STM32H750B-DK",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "Build Debug",
            "type": "shell",
            "command": "${config:cmake.cmakePath}",
            "args": [
                "--build",
                "${workspaceFolder}/build/Debug",
                "-j",
                "8"
            ],
            "group": "build",
            "problemMatcher": "$gcc",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "Build and Flash Board",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Configure Debug",
                "Build Debug",
                "Flash Board"
            ],
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        }
    ]
}
